# ============================================
# .gitignore combinado — Proyecto SSSP Grupo 2
# Cubre C++, Python, Java y LaTeX, ya que cada
# integrante puede usar un lenguaje distinto
# para su implementación.
# ============================================

# ---------- C++ ----------
*.o
*.obj
*.exe
*.out
*.a
*.lib
*.so
*.dll
*.dSYM/
*.exp
*.pdb
*.ilk

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# ---------- Java ----------
*.class
*.jar
*.war
target/
.gradle/
build/

# ---------- LaTeX ----------
*.aux
*.log
*.out
*.toc
*.nav
*.snm
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg
*.bcf
*.run.xml

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Editores / IDEs ----------
.vscode/
.idea/
*.swp
*~

# ---------- Otros ----------
*.log
*.tmp
